using System;

namespace Logica
{
    class program
    {
        static void Main(string[] args)
        {
            int N;
            double[] vet; //declaração de um vetor


            N = int.Parse(Console.ReadLine());
            vet = new double[N]; //Instancia de um vetor


            for (int i=0; i<N; i++)
            {
                vet[i] = double.Parse(Console.ReadLine());
            } //coloca os valores no vetor

            for (int i=0; i<N; i++)
            {
                Console.WriteLine(vet[i].ToString("F1"));
            } // mostra o valor na tela
        }
    }
}
