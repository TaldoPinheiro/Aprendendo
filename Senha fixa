using System;

namespace Logica
{
    class program
    {
        static void Main(string[] args)
        {
            int senha;

            Console.WriteLine("Digite sua senha: ");

            senha = int.Parse(Console.ReadLine());

            while (senha != 2002)
            {
                Console.WriteLine("Senha Inválida!");
                senha = int.Parse(Console.ReadLine());
            }

            Console.WriteLine("Acesso Permitido!");
            
        }
    }
}
